<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Color palette matching the original app ────────────────────── -->
    <SolidColorBrush x:Key="PanelBg"        Color="#0A0A1A"/>
    <SolidColorBrush x:Key="ControlBg"      Color="#12122E"/>
    <SolidColorBrush x:Key="InputBg"        Color="#1A1A34"/>
    <SolidColorBrush x:Key="AccentBrush"    Color="#E94560"/>
    <SolidColorBrush x:Key="TextPrimary"    Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextMuted"      Color="#8899AA"/>
    <SolidColorBrush x:Key="BorderBrush"    Color="#604A00"/>
    <SolidColorBrush x:Key="HoverBrush"     Color="#2A2A44"/>
    <SolidColorBrush x:Key="GoldBrush"      Color="#C8A000"/>
    <SolidColorBrush x:Key="GoldBright"     Color="#FFD700"/>
    <SolidColorBrush x:Key="HoverBanBorder" Color="#FFD700"/>
    <SolidColorBrush x:Key="LockedBanBorder" Color="#E94560"/>

    <!-- ── Section gold border ────────────────────────────────────────── -->
    <Style x:Key="GoldSection" TargetType="Border">
        <Setter Property="BorderBrush"     Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="6,4"/>
        <Setter Property="Margin"          Value="0,4,0,0"/>
    </Style>

    <!-- ── Gold section heading (PICKS, BANS, PLAYERS, etc.) ─────────── -->
    <Style x:Key="GoldHeading" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource GoldBright}"/>
        <Setter Property="FontSize"     Value="15"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="FontFamily"   Value="Impact"/>
        <Setter Property="Margin"       Value="0,0,0,4"/>
    </Style>

    <!-- ── Gold team label (TEAM 1, TEAM 2) ─────────────────────────── -->
    <Style x:Key="TeamLabel" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource GoldBright}"/>
        <Setter Property="FontSize"     Value="22"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="FontFamily"   Value="Impact"/>
        <Setter Property="Margin"       Value="0,0,0,4"/>
    </Style>

    <!-- ── Small muted label ─────────────────────────────────────────── -->
    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource GoldBrush}"/>
        <Setter Property="FontSize"     Value="10"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Margin"       Value="0,6,0,2"/>
    </Style>

    <!-- ── Operator button ───────────────────────────────────────────── -->
    <Style x:Key="OperatorButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource ControlBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── Reset / danger button ─────────────────────────────────────── -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource OperatorButton}">
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
    </Style>

    <!-- ── Input field ───────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background"      Value="{StaticResource InputBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="4,2"/>
        <Setter Property="CaretBrush"      Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- ── ComboBox ──────────────────────────────────────────────────── -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource InputBg}"/>
        <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource GoldBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- ── CheckBox ──────────────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

</ResourceDictionary>
