<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Operator UI colors -->
    <SolidColorBrush x:Key="PanelBg"      Color="#1A1A2E"/>
    <SolidColorBrush x:Key="ControlBg"    Color="#16213E"/>
    <SolidColorBrush x:Key="AccentBrush"  Color="#E94560"/>
    <SolidColorBrush x:Key="TextPrimary"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextMuted"    Color="#8899AA"/>
    <SolidColorBrush x:Key="BorderBrush"  Color="#0F3460"/>
    <SolidColorBrush x:Key="HoverBrush"   Color="#E9456033"/>

    <!-- Slot highlight for hovered bans -->
    <SolidColorBrush x:Key="HoverBanBorder"  Color="#FFD700"/>
    <SolidColorBrush x:Key="LockedBanBorder" Color="#E94560"/>

    <Style x:Key="OperatorButton" TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource ControlBg}"/>
        <Setter Property="Foreground"   Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"  Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"      Value="8,4"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource HoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource OperatorButton}">
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground"  Value="{StaticResource AccentBrush}"/>
    </Style>

    <Style x:Key="SectionLabel" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource TextMuted}"/>
        <Setter Property="FontSize"    Value="10"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Margin"      Value="0,8,0,2"/>
    </Style>

</ResourceDictionary>
