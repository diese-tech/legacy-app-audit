<Window x:Class="SmitePnB.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Background="{StaticResource PanelBg}"
        Foreground="{StaticResource TextPrimary}"
        Width="1280" Height="740"
        MinWidth="1100" MinHeight="660"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Grid Margin="8,6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="175"/>  <!-- Team 1 -->
            <ColumnDefinition Width="*"/>    <!-- Picks + Bans center -->
            <ColumnDefinition Width="175"/>  <!-- Team 2 -->
            <ColumnDefinition Width="1"/>    <!-- Gold divider -->
            <ColumnDefinition Width="330"/>  <!-- Right panel -->
        </Grid.ColumnDefinitions>

        <!-- ══ TEAM 1 column ═══════════════════════════════════════════════ -->
        <DockPanel Grid.Column="0" Margin="0,0,6,0" LastChildFill="False">

            <TextBlock DockPanel.Dock="Top" Text="TEAM 1"
                       Style="{StaticResource TeamLabel}"/>

            <ComboBox  x:Name="CmbTeamOne" DockPanel.Dock="Top"
                       SelectionChanged="CmbTeamOne_Changed" Margin="0,0,0,8"/>

            <TextBlock DockPanel.Dock="Top" Text="SCORE"
                       Style="{StaticResource SectionLabel}"/>

            <TextBox   x:Name="TxtLeftScore" DockPanel.Dock="Top"
                       Width="70" HorizontalAlignment="Left"
                       Text="0" MaxLength="2"
                       TextChanged="Score_Changed"/>
        </DockPanel>

        <!-- ══ CENTER: Picks + Bans ═════════════════════════════════════════ -->
        <DockPanel Grid.Column="1" LastChildFill="False">

            <!-- Top action strip -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="New Draft"    Style="{StaticResource OperatorButton}"
                        Click="BtnNewDraft_Click" Margin="0,0,4,0"/>
                <CheckBox x:Name="ChkShowGodNames" Content="God Names" IsChecked="True"
                          Checked="ChkShowGodNames_Changed" Unchecked="ChkShowGodNames_Changed"
                          VerticalAlignment="Center" Margin="4,0"/>
            </StackPanel>

            <!-- ── PICKS section ──────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Style="{StaticResource GoldSection}">
                <StackPanel>

                    <!-- Header row: PICKS label | "LOCKED IN" over checkbox col -->
                    <Grid Margin="0,0,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="22"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Grid.ColumnSpan="5"
                                   Text="PICKS" Style="{StaticResource GoldHeading}"
                                   HorizontalAlignment="Left"/>
                        <TextBlock Grid.Column="2"
                                   Text="LOCKED IN" FontSize="9"
                                   Foreground="{StaticResource GoldBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"/>
                    </Grid>

                    <!-- 5 paired pick rows -->
                    <ItemsControl x:Name="PickPairList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="30" Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>  <!-- T1 row# -->
                                        <ColumnDefinition Width="*"/>   <!-- T1 god combo -->
                                        <ColumnDefinition Width="30"/>  <!-- T1 lock -->
                                        <ColumnDefinition Width="30"/>  <!-- T2 lock -->
                                        <ColumnDefinition Width="*"/>   <!-- T2 god combo -->
                                        <ColumnDefinition Width="22"/>  <!-- T2 row# -->
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding RowNum}"
                                               Foreground="{StaticResource GoldBrush}"
                                               FontWeight="Bold" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Gods}"
                                              SelectedItem="{Binding T1God, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              SelectionChanged="PickT1God_Changed"
                                              Margin="2,0"/>

                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding T1Locked, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              Checked="PickT1Lock_Changed"
                                              Unchecked="PickT1Lock_Changed"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                                    <CheckBox Grid.Column="3"
                                              IsChecked="{Binding T2Locked, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              Checked="PickT2Lock_Changed"
                                              Unchecked="PickT2Lock_Changed"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                                    <ComboBox Grid.Column="4"
                                              ItemsSource="{Binding Gods}"
                                              SelectedItem="{Binding T2God, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              SelectionChanged="PickT2God_Changed"
                                              Margin="2,0"/>

                                    <TextBlock Grid.Column="5" Text="{Binding RowNum}"
                                               Foreground="{StaticResource GoldBrush}"
                                               FontWeight="Bold" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="RESET" Style="{StaticResource DangerButton}"
                            HorizontalAlignment="Center" Margin="0,4,0,0" Padding="16,3"
                            Click="BtnResetPicks_Click"/>
                </StackPanel>
            </Border>

            <!-- ── BANS section ───────────────────────────────────────── -->
            <Border DockPanel.Dock="Top" Style="{StaticResource GoldSection}">
                <StackPanel>

                    <TextBlock Text="BANS" Style="{StaticResource GoldHeading}"/>

                    <!-- 5 paired ban rows -->
                    <ItemsControl x:Name="BanPairList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="30" Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>  <!-- T1 row# -->
                                        <ColumnDefinition Width="*"/>   <!-- T1 combo -->
                                        <ColumnDefinition Width="24"/>  <!-- T1 lock -->
                                        <ColumnDefinition Width="24"/>  <!-- T2 lock -->
                                        <ColumnDefinition Width="*"/>   <!-- T2 combo -->
                                        <ColumnDefinition Width="22"/>  <!-- T2 row# -->
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding RowNum}"
                                               Foreground="{StaticResource GoldBrush}"
                                               FontWeight="Bold" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>

                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding Gods}"
                                              SelectedItem="{Binding T1God, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              SelectionChanged="BanT1God_Changed"
                                              Margin="2,0"/>

                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding T1Locked, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              Checked="BanT1Lock_Changed"
                                              Unchecked="BanT1Lock_Changed"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ToolTip="Lock ban for data recording"/>

                                    <CheckBox Grid.Column="3"
                                              IsChecked="{Binding T2Locked, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              Checked="BanT2Lock_Changed"
                                              Unchecked="BanT2Lock_Changed"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              ToolTip="Lock ban for data recording"/>

                                    <ComboBox Grid.Column="4"
                                              ItemsSource="{Binding Gods}"
                                              SelectedItem="{Binding T2God, Mode=TwoWay}"
                                              Tag="{Binding}"
                                              SelectionChanged="BanT2God_Changed"
                                              Margin="2,0"/>

                                    <TextBlock Grid.Column="5" Text="{Binding RowNum}"
                                               Foreground="{StaticResource GoldBrush}"
                                               FontWeight="Bold" VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <Button Content="⇄" Style="{StaticResource OperatorButton}"
                                Click="BtnSwapTeams_Click" Margin="0,0,6,0" Padding="12,3"
                                ToolTip="Swap team sides"/>
                        <Button Content="RESET" Style="{StaticResource DangerButton}"
                                Click="BtnResetBans_Click" Padding="16,3"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </DockPanel>

        <!-- ══ TEAM 2 column ═══════════════════════════════════════════════ -->
        <DockPanel Grid.Column="2" Margin="6,0,0,0" LastChildFill="False">

            <TextBlock DockPanel.Dock="Top" Text="TEAM 2"
                       Style="{StaticResource TeamLabel}"
                       HorizontalAlignment="Right"/>

            <ComboBox  x:Name="CmbTeamTwo" DockPanel.Dock="Top"
                       SelectionChanged="CmbTeamTwo_Changed" Margin="0,0,0,8"/>

            <TextBlock DockPanel.Dock="Top" Text="SCORE"
                       Style="{StaticResource SectionLabel}"
                       HorizontalAlignment="Right"/>

            <TextBox   x:Name="TxtRightScore" DockPanel.Dock="Top"
                       Width="70" HorizontalAlignment="Right"
                       Text="0" MaxLength="2"
                       TextChanged="Score_Changed"/>
        </DockPanel>

        <!-- ══ Gold vertical divider ══════════════════════════════════════ -->
        <Rectangle Grid.Column="3" Fill="{StaticResource GoldBrush}" Margin="6,0"/>

        <!-- ══ RIGHT PANEL ════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto" Margin="6,0,0,0">
            <StackPanel>

                <!-- ── PLAYERS ─────────────────────────────────────────── -->
                <Border Style="{StaticResource GoldSection}">
                    <StackPanel>
                        <TextBlock Text="PLAYERS" Style="{StaticResource GoldHeading}"/>

                        <!-- Column header -->
                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="56"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="TEAM 1" FontSize="9"
                                       Foreground="{StaticResource GoldBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="TEAM 2" FontSize="9"
                                       Foreground="{StaticResource GoldBrush}"
                                       HorizontalAlignment="Center"/>
                        </Grid>

                        <ItemsControl x:Name="PlayerRowList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="26" Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="18"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding RowNum}"
                                                   Foreground="{StaticResource GoldBrush}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>

                                        <TextBox Grid.Column="1"
                                                 Text="{Binding T1Player, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Tag="{Binding}"
                                                 LostFocus="PlayerT1_LostFocus"
                                                 FontSize="11" Margin="2,0"/>

                                        <TextBlock Grid.Column="2" Text="{Binding Role}"
                                                   Foreground="{StaticResource GoldBrush}"
                                                   FontSize="10" FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <TextBox Grid.Column="3"
                                                 Text="{Binding T2Player, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Tag="{Binding}"
                                                 LostFocus="PlayerT2_LostFocus"
                                                 FontSize="11" Margin="2,0"/>

                                        <TextBlock Grid.Column="4" Text="{Binding RowNum}"
                                                   Foreground="{StaticResource GoldBrush}"
                                                   FontSize="10" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ── BAN DATA ────────────────────────────────────────── -->
                <Border Style="{StaticResource GoldSection}">
                    <StackPanel>
                        <TextBlock Text="BAN DATA" Style="{StaticResource GoldHeading}"/>
                        <Button Content="SUBMIT BAN DATA"
                                Style="{StaticResource OperatorButton}"
                                Click="BtnSubmitBans_Click"
                                HorizontalAlignment="Left" Padding="10,4" Margin="0,0,0,4"/>
                        <TextBlock Text="VISIBILITY" FontSize="9"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,2,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox x:Name="ChkBanVisT1" Content="TEAM 1"
                                      Foreground="{StaticResource GoldBrush}"
                                      FontSize="10" IsChecked="True" Margin="0,0,10,0"/>
                            <CheckBox x:Name="ChkBanVisT2" Content="TEAM 2"
                                      Foreground="{StaticResource GoldBrush}"
                                      FontSize="10" IsChecked="True"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── VARIOUS ─────────────────────────────────────────── -->
                <Border Style="{StaticResource GoldSection}">
                    <StackPanel>
                        <TextBlock Text="VARIOUS" Style="{StaticResource GoldHeading}"/>

                        <!-- Resources path -->
                        <TextBlock Text="RESOURCES PATH" FontSize="9"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,2,0,2"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtResourcesPath" Grid.Column="0"
                                     FontSize="10" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="…"
                                    Style="{StaticResource OperatorButton}"
                                    Click="BtnBrowseResources_Click"
                                    Padding="6,2" Margin="4,0,0,0"/>
                        </Grid>

                        <!-- Resolution -->
                        <TextBlock Text="RESOLUTION" FontSize="9"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,2,0,2"/>
                        <ComboBox x:Name="CmbResolution" Margin="0,0,0,6"
                                  SelectionChanged="CmbResolution_Changed">
                            <ComboBoxItem Content="1600 × 900"/>
                            <ComboBoxItem Content="1920 × 1080"/>
                            <ComboBoxItem Content="2560 × 1440"/>
                        </ComboBox>

                        <!-- Show God Names (inline copy synced with top checkbox) -->
                        <CheckBox x:Name="ChkShowGodNamesVarious" Content="SHOW GOD NAMES"
                                  Foreground="{StaticResource GoldBrush}"
                                  FontSize="10" IsChecked="True"
                                  Checked="ChkShowGodNamesVarious_Changed"
                                  Unchecked="ChkShowGodNamesVarious_Changed"
                                  Margin="0,0,0,6"/>

                        <!-- Window shortcuts -->
                        <TextBlock Text="STREAM WINDOWS" FontSize="9"
                                   Foreground="{StaticResource GoldBrush}" Margin="0,2,0,2"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button Content="P/B Display"
                                    Style="{StaticResource OperatorButton}"
                                    Click="BtnShowDisplay_Click"
                                    FontSize="10" Padding="6,3" Margin="0,0,4,0"/>
                            <Button Content="In-Game Overlay"
                                    Style="{StaticResource OperatorButton}"
                                    Click="BtnShowOverlay_Click"
                                    FontSize="10" Padding="6,3"/>
                        </StackPanel>

                        <!-- Advanced section -->
                        <Separator Background="{StaticResource GoldBrush}" Margin="0,4,0,4"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Gods…"
                                    Style="{StaticResource OperatorButton}"
                                    Click="BtnGodManager_Click"
                                    Padding="8,3" Margin="0,0,4,0" FontSize="10"/>
                            <Button Content="Advanced Settings"
                                    Style="{StaticResource OperatorButton}"
                                    Click="BtnSettings_Click"
                                    Padding="8,3" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Window>
