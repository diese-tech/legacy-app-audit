<Window x:Class="SmitePnB.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Background="{StaticResource PanelBg}"
        Foreground="{StaticResource TextPrimary}"
        Width="960" Height="780"
        MinWidth="900" MinHeight="700"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- ComboBox dark style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background"  Value="{StaticResource ControlBg}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="Padding"     Value="4,2"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="10">

        <!-- ── Top bar ─────────────────────────────────────────────────── -->
        <ToolBar DockPanel.Dock="Top" Background="{StaticResource ControlBg}" Margin="0,0,0,8">
            <Button x:Name="BtnNewDraft"   Content="New Draft"    Style="{StaticResource OperatorButton}" Click="BtnNewDraft_Click"   ToolTip="Clear all picks and bans"/>
            <Button x:Name="BtnSubmitBans" Content="Submit Bans"  Style="{StaticResource OperatorButton}" Click="BtnSubmitBans_Click" ToolTip="Record this game's ban data and increment game count"/>
            <Separator/>
            <Button x:Name="BtnSwapTeams"  Content="⇄ Swap Teams" Style="{StaticResource OperatorButton}" Click="BtnSwapTeams_Click"  ToolTip="Swap left/right team sides"/>
            <Separator/>
            <CheckBox x:Name="ChkShowGodNames" Content="God Names" IsChecked="True"
                      Checked="ChkShowGodNames_Changed" Unchecked="ChkShowGodNames_Changed"
                      VerticalAlignment="Center" Margin="4,0"/>
            <Separator/>
            <Button x:Name="BtnGodManager" Content="Gods…"     Style="{StaticResource OperatorButton}" Click="BtnGodManager_Click" ToolTip="Add or remove gods, check which assets are present"/>
            <Button x:Name="BtnSettings"   Content="⚙ Config"  Style="{StaticResource OperatorButton}" Click="BtnSettings_Click" ToolTip="App configuration: paths, colors, layout"/>
            <Separator/>
            <Button x:Name="BtnShowDisplay" Content="P/B Display"      Style="{StaticResource OperatorButton}" Click="BtnShowDisplay_Click"  ToolTip="Bring the P/B Display stream window to front"/>
            <Button x:Name="BtnShowOverlay" Content="In-Game Overlay"  Style="{StaticResource OperatorButton}" Click="BtnShowOverlay_Click"  ToolTip="Bring the In-Game Overlay stream window to front"/>
            <Separator/>
            <Button x:Name="BtnAbout"      Content="About"      Style="{StaticResource OperatorButton}" Click="BtnAbout_Click"/>
        </ToolBar>

        <!-- ── Score row ───────────────────────────────────────────────── -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="40"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Left Score"  Style="{StaticResource SectionLabel}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0"/>
            <TextBox   x:Name="TxtLeftScore"  Grid.Column="1" Width="50" HorizontalAlignment="Left" Text="0" TextChanged="Score_Changed" MaxLength="2"/>
            <TextBlock Grid.Column="2" Text="—" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}"/>
            <TextBox   x:Name="TxtRightScore" Grid.Column="3" Width="50" HorizontalAlignment="Left" Text="0" TextChanged="Score_Changed" MaxLength="2"/>
        </Grid>

        <!-- ── Main draft panel ────────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>   <!-- Team One -->
                <ColumnDefinition Width="12"/>  <!-- gutter -->
                <ColumnDefinition Width="*"/>   <!-- Team Two -->
            </Grid.ColumnDefinitions>

            <!-- ── Team One ─────────────────────────────────────────────── -->
            <StackPanel Grid.Column="0">
                <!-- Team selector -->
                <TextBlock Text="TEAM ONE (LEFT)" Style="{StaticResource SectionLabel}"/>
                <ComboBox x:Name="CmbTeamOne" SelectionChanged="CmbTeamOne_Changed" Margin="0,0,0,4"/>

                <!-- Bans -->
                <TextBlock Text="BANS" Style="{StaticResource SectionLabel}"/>
                <ItemsControl x:Name="TeamOneBanList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <ComboBox  Grid.Column="1" ItemsSource="{Binding Gods}" SelectedItem="{Binding GodName, Mode=TwoWay}"
                                           SelectionChanged="BanGod_Changed" Tag="{Binding}" Margin="0,0,4,0"/>
                                <CheckBox  Grid.Column="2" Content="Hover" IsChecked="{Binding IsHovered, Mode=TwoWay}"
                                           Checked="BanHover_Changed" Unchecked="BanHover_Changed" Tag="{Binding}" VerticalAlignment="Center"/>
                                <CheckBox  Grid.Column="3" Content="Lock"  IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                           Checked="BanLock_Changed"  Unchecked="BanLock_Changed"  Tag="{Binding}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Reset Bans" Style="{StaticResource DangerButton}" Margin="0,4,0,0"
                        Click="BtnResetTeamOneBans_Click"/>

                <!-- Picks -->
                <TextBlock Text="PICKS" Style="{StaticResource SectionLabel}"/>
                <ItemsControl x:Name="TeamOnePickList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Role}" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <ComboBox  Grid.Column="1" ItemsSource="{Binding Gods}" SelectedItem="{Binding GodName, Mode=TwoWay}"
                                           SelectionChanged="PickGod_Changed" Tag="{Binding}" Margin="0,0,4,0"/>
                                <CheckBox  Grid.Column="2" Content="Lock" IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                           Checked="PickLock_Changed" Unchecked="PickLock_Changed" Tag="{Binding}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Reset Picks" Style="{StaticResource DangerButton}" Margin="0,4,0,0"
                        Click="BtnResetTeamOnePicks_Click"/>
            </StackPanel>

            <!-- ── Team Two ─────────────────────────────────────────────── -->
            <StackPanel Grid.Column="2">
                <TextBlock Text="TEAM TWO (RIGHT)" Style="{StaticResource SectionLabel}"/>
                <ComboBox x:Name="CmbTeamTwo" SelectionChanged="CmbTeamTwo_Changed" Margin="0,0,0,4"/>

                <TextBlock Text="BANS" Style="{StaticResource SectionLabel}"/>
                <ItemsControl x:Name="TeamTwoBanList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <ComboBox  Grid.Column="1" ItemsSource="{Binding Gods}" SelectedItem="{Binding GodName, Mode=TwoWay}"
                                           SelectionChanged="BanGod_Changed" Tag="{Binding}" Margin="0,0,4,0"/>
                                <CheckBox  Grid.Column="2" Content="Hover" IsChecked="{Binding IsHovered, Mode=TwoWay}"
                                           Checked="BanHover_Changed" Unchecked="BanHover_Changed" Tag="{Binding}" VerticalAlignment="Center"/>
                                <CheckBox  Grid.Column="3" Content="Lock"  IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                           Checked="BanLock_Changed"  Unchecked="BanLock_Changed"  Tag="{Binding}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Reset Bans" Style="{StaticResource DangerButton}" Margin="0,4,0,0"
                        Click="BtnResetTeamTwoBans_Click"/>

                <TextBlock Text="PICKS" Style="{StaticResource SectionLabel}"/>
                <ItemsControl x:Name="TeamTwoPickList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Role}" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="11"/>
                                <ComboBox  Grid.Column="1" ItemsSource="{Binding Gods}" SelectedItem="{Binding GodName, Mode=TwoWay}"
                                           SelectionChanged="PickGod_Changed" Tag="{Binding}" Margin="0,0,4,0"/>
                                <CheckBox  Grid.Column="2" Content="Lock" IsChecked="{Binding IsLocked, Mode=TwoWay}"
                                           Checked="PickLock_Changed" Unchecked="PickLock_Changed" Tag="{Binding}" VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button Content="Reset Picks" Style="{StaticResource DangerButton}" Margin="0,4,0,0"
                        Click="BtnResetTeamTwoPicks_Click"/>
            </StackPanel>
        </Grid>

    </DockPanel>
</Window>
