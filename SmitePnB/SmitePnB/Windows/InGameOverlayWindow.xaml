<Window x:Class="SmitePnB.Windows.InGameOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="In-Game Overlay"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#00FF00"
        ShowInTaskbar="True"
        SizeToContent="Manual">

    <!--
        Green-screen stream window captured by OBS via window_capture ("In-Game Overlay").
        Background #00FF00 is chroma-keyed out in OBS; team art panels and pick portraits
        remain visible.  All positions come from LayoutConfig (overlay* fields).
    -->
    <Canvas x:Name="RootCanvas" Background="#00FF00">

        <!-- ── Team art panels (Left.png / Right.png from team folder) ── -->
        <Image x:Name="LeftArtImg"
               Canvas.Left="0" Canvas.Top="0"
               Stretch="Fill"/>
        <Image x:Name="RightArtImg"
               Canvas.Left="0" Canvas.Top="0"
               Stretch="Fill"/>

        <!-- ── Team names ────────────────────────────────────────────── -->
        <TextBlock x:Name="LeftTeamName"  Canvas.Left="0" Canvas.Top="0"
                   Foreground="White" FontFamily="Impact" FontSize="28"
                   TextAlignment="Left"/>
        <TextBlock x:Name="RightTeamName" Canvas.Left="0" Canvas.Top="0"
                   Foreground="White" FontFamily="Impact" FontSize="28"
                   TextAlignment="Left"/>

        <!-- ── Scores ─────────────────────────────────────────────────── -->
        <TextBlock x:Name="LeftScore"  Canvas.Left="0" Canvas.Top="0"
                   Foreground="White" FontFamily="Impact" FontSize="48"
                   TextAlignment="Center" Text="0"/>
        <TextBlock x:Name="RightScore" Canvas.Left="0" Canvas.Top="0"
                   Foreground="White" FontFamily="Impact" FontSize="48"
                   TextAlignment="Center" Text="0"/>

        <!-- ── Pick slots generated in code-behind ────────────────────── -->
        <!-- LeftPick0..4 and RightPick0..4 -->

    </Canvas>
</Window>
